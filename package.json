{
  "name": "@textrefs/registry",
  "type": "module",
  "private": true,
  "version": "0.0.0",
  "license": "CC0-1.0",
  "description": "Hand-authored seed registry data for TextRefs.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/textrefs/registry.git"
  },
  "scripts": {
    "changelog": "git-cliff -o CHANGELOG.md",
    "changelog:unreleased": "git-cliff --unreleased --prepend CHANGELOG.md",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{yml,yaml,md,json}": "prettier --write"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.0.1",
    "@commitlint/config-conventional": "^21.0.1",
    "git-cliff": "^2.13.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "prettier": "^3.8.3"
  }
}
